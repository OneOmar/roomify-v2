# ============================================================================
# Supabase
# ============================================================================
# Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only service role key (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# Public Storage bucket used by upload + generated image flows
NEXT_PUBLIC_SUPABASE_UPLOAD_BUCKET=uploads


# ============================================================================
# Clerk Authentication
# ============================================================================
# Dashboard -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Auth routes (must match your App Router pages)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard


# ============================================================================
# AI Image Generation
# ============================================================================
# fake: no external call (echoes input URL)
# huggingface: calls stabilityai/stable-diffusion-2-1
AI_IMAGE_PROVIDER=fake

# Required only when AI_IMAGE_PROVIDER=huggingface
# https://huggingface.co/settings/tokens
HF_TOKEN=
# Optional override if default model is not available for hf-inference
HF_MODEL_ID=stabilityai/stable-diffusion-2-1
# Optional comma-separated fallbacks (tried in order)
# HF_FALLBACK_MODEL_IDS=black-forest-labs/FLUX.1-schnell,stabilityai/stable-diffusion-xl-base-1.0
